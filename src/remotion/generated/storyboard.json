    {
      "id": "scene_3",
      "type": "code",
      "startTime": 26.200000000000003,
      "duration": 10.364,
      "narration": "Let's build a dynamic route type. By using backticks inside our type definition, we can enforce that every route must start strictly with '/api/'.",
      "visualDescription": "VS Code editor typing out a template literal type. The cursor blinks and types smoothly, highlighting the syntax as it goes.",
      "codeSnippet": "type ApiRoute = `/api/${string}`;\n\nfunction secureFetch(route: ApiRoute) {\n  return fetch(route);\n}\n\n// ❌ Compiler Error!\nsecureFetch(\"api/users\");\n\n// ✅ Allowed!\nsecureFetch(\"/api/users\");",
      "language": "typescript",
