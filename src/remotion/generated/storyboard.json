      "id": "scene_4",
      "type": "code",
      "startTime": 36.56400000000001,
      "duration": 13.508,
      "narration": "We can take this even further. Let's restrict the route to specific resources like 'users' or 'posts', followed strictly by a numeric ID. Watch the compiler block invalid IDs.",
      "visualDescription": "VS Code showing an advanced type definition. We see the compiler instantly flags a route with a non-numeric ID.",
      "codeSnippet": "type Resource = \"users\" | \"posts\";\ntype StrictRoute = `/api/${Resource}/${number}`;\n\nfunction get(route: StrictRoute) {\n  return fetch(route);\n}\n\n// ❌ Error: 'abc' is not a number\nget(\"/api/users/abc\");\n\n// ✅ Perfect!\nget(\"/api/users/123\");",
