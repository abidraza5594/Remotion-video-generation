{
  "name": "cinematic-ai-studio",
  "version": "1.0.0",
  "description": "Fully automated cinematic AI tutorial video generation with social media auto-posting",
  "main": "src/cli/index.ts",
  "scripts": {
    "generate-video": "node -r ts-node/register/transpile-only src/cli/index.ts",
    "auth:youtube": "node -r ts-node/register/transpile-only src/cli/index.ts --auth=youtube",
    "auth:instagram": "node -r ts-node/register/transpile-only src/cli/index.ts --auth=instagram",
    "auth:linkedin": "node -r ts-node/register/transpile-only src/cli/index.ts --auth=linkedin",
    "auth:status": "node -r ts-node/register/transpile-only src/cli/index.ts --auth=status",
    "auth:logout": "node -r ts-node/register/transpile-only src/cli/index.ts --auth=logout",
    "auth:switch": "node -r ts-node/register/transpile-only src/cli/index.ts --auth=switch",
    "upload:youtube": "node -r ts-node/register/transpile-only src/cli/index.ts --upload=youtube",
    "render:preview": "remotion preview src/remotion/index.ts",
    "render:mp4": "remotion render src/remotion/index.ts MainComposition out/video.mp4",
    "clean": "rimraf temp output"
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.4.1",
    "@remotion/bundler": "^4.0.190",
    "@remotion/cli": "^4.0.190",
    "@remotion/renderer": "^4.0.190",
    "axios": "^1.7.7",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.1",
    "framer-motion": "^11.11.0",
    "googleapis": "^144.0.0",
    "inquirer": "^8.2.6",
    "open": "^8.4.2",
    "ora": "^5.4.1",
    "prismjs": "^1.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.190",
    "rimraf": "^6.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^22.7.4",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^18.3.11",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
